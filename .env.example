# =============================================
# GROQ API (LLM)
# =============================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================
# EMAIL - SMTP (Gmail)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# Timeout in seconds (increase if you see "semaphore timeout" on Windows)
SMTP_TIMEOUT=90
# Use 1 for port 465 (SSL). Use 0 or leave unset for port 587 (STARTTLS).
# SMTP_USE_TLS=1

# =============================================
# EMAIL - IMAP (for reply monitoring)
# =============================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your_email@gmail.com
IMAP_PASSWORD=your_app_password

# =============================================
# CALENDAR
# =============================================
CALENDAR_LINK=https://calendly.com/your-link/30min

# =============================================
# SYSTEM SETTINGS
# =============================================
DB_PATH=leads.db
MAX_CONCURRENT_LEADS=5
REPLY_CHECK_INTERVAL_MINUTES=5
LOG_LEVEL=INFO

# Set to 1 to auto-approve insights and email drafts (no keyboard prompts)
AUTO_APPROVE=0

# Leave unset or 0 to send real emails. Set to 1 to only simulate sends.
# DRY_RUN_EMAILS=1
